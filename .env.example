# Local Supabase default:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable"

# Production Supabase direct/pooler URL:
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Required only if the app later uses Supabase Storage/Auth client-side:
# NEXT_PUBLIC_SUPABASE_URL="https://umockhnaabuxdmeeyszy.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="[PUBLISHABLE_KEY]"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="[LEGACY_ANON_OR_PUBLISHABLE_KEY]"

# E-mails transactionnels côté serveur uniquement.
# Requis pour envoyer les liens "mot de passe oublié" utilisateurs, pharmacies et admin.
APP_URL="http://localhost:3000"
SABLIN_EMAIL_FROM="SABLIN PHARMA <no-reply@sablin.ci>"
RESEND_API_KEY=

# Enrichissement Google/Web côté serveur uniquement.
# Désactivé par défaut : la plateforme utilise le référentiel interne, les images validées et le placeholder SABLIN PHARMA.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
ENABLE_EXTERNAL_ENRICHMENT=false
ENRICHMENT_DAILY_LIMIT=100
ENRICHMENT_CONFIDENCE_THRESHOLD=85
